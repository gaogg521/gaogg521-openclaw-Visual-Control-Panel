# 复制本文件为同目录下的 wizard.env 后填写（勿提交真实 Key）
# onboard 参考: https://docs.openclaw.ai/start/wizard-cli-automation

# 模型厂商（与 openclaw onboard --auth-choice 一致，示例）
# anthropic-api-key | openai-api-key | moonshot-api-key | gemini-api-key | ollama | custom-api-key | ...
AUTH_CHOICE=openai-api-key

# 网关（默认与龙虾面板探测逻辑一致）
GATEWAY_PORT=18789
GATEWAY_BIND=loopback

# —— 各厂商 Key（按 AUTH_CHOICE 只填需要的）——
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=

# Ollama 时填写模型 id，并建议 ACCEPT_RISK=1
CUSTOM_MODEL_ID=
ACCEPT_RISK=0

# custom-api-key 时填写
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_PROVIDER_ID=my-custom
CUSTOM_COMPATIBILITY=openai

# 是否安装为守护进程（推荐 true）
INSTALL_DAEMON=1
DAEMON_RUNTIME=node
SKIP_SKILLS=1
