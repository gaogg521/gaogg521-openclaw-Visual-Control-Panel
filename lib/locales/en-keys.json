    "key": "models.addProbeModeOpenClaw",
    "value": "OpenClaw provider (LiteLLM, etc.)"
  },
  {
    "key": "models.addProbeModeCustomHttp",
    "value": "Custom / vendor HTTP (base URL + protocol)"
  },
  {
    "key": "models.addProbeModeHint",
    "value": "LiteLLM is just one common provider shape; pick Custom HTTP for your own gateway. If you select a toolbar probe preset, that preset’s URL/protocol takes precedence for the test (you still pick the save target provider below)."
  },
  {
    "key": "models.openClawGatewayHelpTitle",
    "value": "OpenClaw / gateway fields (incl. LiteLLM)"
  },
  {
    "key": "models.openClawGatewayHelpBody",
    "value": "• models.providers.<id>.baseUrl: gateway root (openai-completions → /chat/completions; anthropic-messages → /v1/messages).\n• api: often \"openai-completions\" or \"anthropic-messages\".\n• apiKey: key for the gateway; may combine with auth.profiles.\n\nmodels[] entry: id (must match upstream route), name, contextWindow, maxTokens, input, reasoning.\n\nProbes merge agents/<Agent>/agent/models.json, main, and openclaw.json; ALL_CAPS apiKey reads from env."
  },
  {
    "key": "models.customHttpHelpTitle",
    "value": "Custom / vendor HTTP probe"
  },
  {
    "key": "models.customHttpHelpBody",
    "value": "Set root URL (no path suffix), protocol, and the temporary API key in the toolbar. Only this request is direct-probed; saving still writes to the expanded provider block."
  },
  {
    "key": "models.customHttpBaseUrl",
    "value": "Gateway base URL"
  },
  {
    "key": "models.customHttpProtocol",
    "value": "Protocol (HTTP path style)"
  },
  {
    "key": "models.fieldModel",
    "value": "model (API model id)"
  },
  {
    "key": "models.fieldModelPlaceholder",
    "value": "e.g. qwen3-max, gpt-4o"
  },
  {
    "key": "models.fieldModelProvider",
    "value": "model_provider (vendor label, optional)"
  },
  {
    "key": "models.fieldModelProviderPlaceholder",
    "value": "e.g. JoyMaas, self-hosted"
  },
  {
    "key": "models.addFormUsesAgent",
    "value": "Probe context (tests only):"
  },
  {
    "key": "models.addFormUsesAgentSuffix",
    "value": "(same as toolbar; only openclaw.json; picking an Agent also binds agents.list + defaults.models)"
  },
  {
    "key": "models.liteLlmHelpTitle",
    "value": "LiteLLM / openclaw.json model fields"
  },
  {
    "key": "models.liteLlmHelpBody",
    "value": "• models.providers.<id>.baseUrl: your LiteLLM base URL (OpenClaw builds OpenAI-compatible paths).\n• api: usually \"openai-completions\".\n• apiKey: key sent to LiteLLM; may work together with auth.profiles.\n\nEach item in models[] typically has: id (must match LiteLLM route name), name, contextWindow, maxTokens, input (e.g. [\"text\",\"image\"]), reasoning.\n\nThe dashboard probe merges openclaw.json with agents/main/agent/models.json. ALL_CAPS apiKey placeholders (e.g. LITELLM_API_KEY) are resolved from environment variables. If only the placeholder was used before, LiteLLM often returns \"invalid key\"."
  },
